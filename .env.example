# -*- coding: utf-8 -*-
# ===================================
# Daily Stock Analysis 环境变量配置示例
# ===================================
# 
# 说明：
# 1. 复制此文件为 .env 并填入真实配置
# 2. .env 文件已在 .gitignore 中，不会被提交到 GitHub
# 3. 所有配置项均为可选，未配置时使用默认值
# ===================================

# ===================================
# 数据源配置
# ===================================
# 数据源优先级（akshare/efinance/tushare）
DATA_SOURCE_PRIORITY=akshare,efinance,tushare

# 是否启用缓存
DATA_CACHE_ENABLED=true

# 缓存有效期（小时）
DATA_CACHE_TTL_HOURS=1

# Tushare API Token（可选）
# 获取地址：https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# ===================================
# 豆包API配置
# ===================================
# 豆包API密钥（必填）
# 获取地址：https://console.volcengine.com/ark
DOUBAO_API_KEY=your_doubao_api_key_here

# 豆包模型ID
DOUBAO_MODEL=Doubao-Seedream-5.0-lite

# 豆包API地址
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 最大Token数
DOUBAO_MAX_TOKENS=1000

# 温度参数（0.0-1.0）
DOUBAO_TEMPERATURE=0.7

# 是否启用推送
DOUBAO_PUSH_ENABLED=true

# 重试次数
DOUBAO_RETRY_TIMES=3

# 重试延迟（秒）
DOUBAO_RETRY_DELAY=5

# 是否启用Token监控
DOUBAO_TOKEN_MONITOR_ENABLED=true

# Token阈值百分比（剩余<此值时切换轻量化推理）
DOUBAO_TOKEN_THRESHOLD_PERCENT=10.0

# ===================================
# 策略配置
# ===================================
# 股票价格范围（元）
STRATEGY_PRICE_MIN=5.0
STRATEGY_PRICE_MAX=35.0

# 换手率范围（%）
STRATEGY_TURNOVER_RATE_MIN=3.0
STRATEGY_TURNOVER_RATE_MAX=10.0

# 量比阈值
STRATEGY_VOLUME_RATIO_THRESHOLD=1.5

# 持有天数
STRATEGY_HOLD_DAYS=2

# 止损百分比
STRATEGY_STOP_LOSS_PERCENT=3.0

# 选股时间（HH:MM）
STRATEGY_SELECTION_TIME=14:30

# 回测日（Sunday/Monday/Tuesday/Wednesday/Thursday/Friday/Saturday）
STRATEGY_BACKTEST_DAY=Sunday

# 回测时间（HH:MM）
STRATEGY_BACKTEST_TIME=20:00

# 板块数量
STRATEGY_TOP_SECTORS_COUNT=10

# 推荐股票数量
STRATEGY_MAX_RECOMMENDATIONS=10

# ===================================
# 定时任务配置
# ===================================
# 是否启用定时任务
SCHEDULE_ENABLED=true

# 数据下载时间（逗号分隔）
SCHEDULE_DATA_DOWNLOAD_TIMES=09:30,14:00

# 选股时间（HH:MM）
SCHEDULE_SELECTION_TIME=14:30

# 选股日期（逗号分隔）
SCHEDULE_SELECTION_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday

# 回测时间（HH:MM）
SCHEDULE_BACKTEST_TIME=20:00

# 回测日
SCHEDULE_BACKTEST_DAY=Sunday

# 复盘时间（HH:MM）
SCHEDULE_REVIEW_TIME=09:00

# 复盘日期（逗号分隔）
SCHEDULE_REVIEW_DAYS=Monday,Tuesday,Wednesday,Thursday,Friday

# ===================================
# 可视化配置
# ===================================
# UI框架（tkinter/streamlit）
VISUALIZATION_UI_FRAMEWORK=tkinter

# UI标题
VISUALIZATION_UI_TITLE=股票走势预测

# UI尺寸
VISUALIZATION_UI_SIZE=1200x800

# 图表样式
VISUALIZATION_CHART_STYLE=seaborn

# 预测天数
VISUALIZATION_PREDICTION_DAYS=2

# 历史天数
VISUALIZATION_HISTORY_DAYS=30

# 是否启用情绪分析
VISUALIZATION_EMOTION_ANALYSIS_ENABLED=true

# ===================================
# 日志配置
# ===================================
# 日志级别（DEBUG/INFO/WARNING/ERROR/CRITICAL）
LOG_LEVEL=INFO

# 日志目录
LOG_DIR=logs

# 最大日志文件大小（字节）
LOG_MAX_BYTES=10485760

# 日志备份数量
LOG_BACKUP_COUNT=5

# ===================================
# 其他配置
# ===================================
# 项目运行环境（development/production）
ENVIRONMENT=development

# 时区
TIMEZONE=Asia/Shanghai
